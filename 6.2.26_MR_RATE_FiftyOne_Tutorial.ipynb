   "source": [
    "---\n",
    "## Step 1 — Imports\n",
    "Verify you are using the `Python (mr-rate-env)` kernel before running this cell."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code-01",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import zipfile\n",
    "import numpy as np\n",
    "\n",
    "# Patch for NumPy 2.0 compatibility\n",
    "if not hasattr(np, 'unicode_'):\n",
    "    np.unicode_ = np.str_\n",
    "\n",
    "import nibabel as nib\n",
    "import pandas as pd\n",
    "import fiftyone as fo\n",
    "from PIL import Image\n",
    "from huggingface_hub import login, hf_hub_download, list_repo_files\n",
    "\n",
    "print('All imports successful')\n",
    "print(f'NumPy:    {np.__version__}')\n",
    "print(f'FiftyOne: {fo.__version__}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "md-003",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 2 — Login to HuggingFace\n",
    "\n",
    "1. Go to https://huggingface.co/settings/tokens\n",
    "2. Click **New token** → **Read** access → **Create**\n",
    "3. Copy the token (starts with `hf_...`) and paste it below\n",
    "4. Make sure you have accepted dataset terms at https://huggingface.co/datasets/Forithmus/MR-RATE"
   ]
  },
  {
   "cell_type": "code",
