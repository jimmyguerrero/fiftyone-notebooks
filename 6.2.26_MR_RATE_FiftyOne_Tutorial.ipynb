   ]
  },
  {
   "cell_type": "markdown",
   "id": "md-014",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 13 — Compute ResNet18 embeddings\n",
    "\n",
    "Uses a pretrained ResNet18 to extract a 512-dimensional feature vector from each MRI slice.\n",
    "These embeddings capture visual similarity between scans.\n",
    "\n",
    "⏱ Takes ~1–2 minutes. You may see an OpenMP warning — ignore it, it is harmless."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code-13",
   "metadata": {},
   "outputs": [],
   "source": [
    "import fiftyone.brain as fob\n",
    "import torch\n",
    "import torchvision.models as models\n",
    "import torchvision.transforms as transforms\n",
    "\n",
    "# Load ResNet18 with final classification layer removed\n",
    "model = models.resnet18(weights=\"ResNet18_Weights.IMAGENET1K_V1\")\n",
    "model.eval()\n",
    "model = torch.nn.Sequential(*list(model.children())[:-1])\n",
    "\n",
    "transform = transforms.Compose([\n",
    "    transforms.Resize((224, 224)),\n",
    "    transforms.Grayscale(num_output_channels=3),  # MRI is grayscale; ResNet needs 3 channels\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize(\n",
    "        mean=[0.485, 0.456, 0.406],\n",
    "        std=[0.229, 0.224, 0.225]\n",
    "    ),\n",
    "])\n",
    "\n",
    "embeddings = []\n",
    "for i, sample in enumerate(dataset):\n",
    "    img    = Image.open(sample.filepath)\n",
    "    tensor = transform(img).unsqueeze(0)\n",
    "    with torch.no_grad():\n",
    "        emb = model(tensor).squeeze().numpy()\n",
    "    embeddings.append(emb)\n",
    "    if (i + 1) % 50 == 0:\n",
    "        print(f\"  Embedded {i + 1}/{len(dataset)}...\")\n",
    "\n",
    "embeddings = np.array(embeddings)\n",
    "print(f\"\\nEmbeddings shape: {embeddings.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "md-015",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 14 — Compute t-SNE visualization and similarity index\n",
    "\n",
    "- **t-SNE**: reduces 512-dim embeddings to 2D for the scatter plot in the Embeddings panel\n",
    "- **Similarity index**: enables `sort_by_similarity()` search in Step 15\n",
    "\n",
    "⏱ Takes ~1–2 minutes. Ignore any OpenMP warnings."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code-14",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute t-SNE visualization for the Embeddings panel\n",
    "fob.compute_visualization(\n",
    "    dataset,\n",
    "    embeddings=embeddings,\n",
    "    num_dims=2,\n",
    "    method=\"tsne\",\n",
    "    brain_key=\"img_viz\",\n",
    "    verbose=True,\n",
